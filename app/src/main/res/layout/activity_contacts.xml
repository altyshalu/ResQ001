<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    tools:context=".ContactsActivity">

    <!-- Верхняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Назад"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F3460" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Выберите экстренные контакты"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="16dp" />

    </LinearLayout>

    <!-- Панель с кнопкой и счетчиком -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8px">

        <Button
            android:id="@+id/pickContactButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выбрать из контактов"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F3460" />

        <TextView
            android:id="@+id/selectedCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Выбрано: 0/3"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="end" />

    </LinearLayout>

    <!-- Список контактов -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contactsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- Кнопка сохранения -->
    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:backgroundTint="#0F3460"
        android:text="Сохранить контакты"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

</LinearLayout>